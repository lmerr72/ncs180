generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECTING
}

enum ProspectStatus {
  VERBAL
  NOT_STARTED
  IN_COMMUNICATION
  AWAITING_REVIEW
  ONBOARDING
  CLOSED
}

enum ClientIntegration {
  YARDI
  ENTRATA
  ONESITE
  RESMAN
  RENT_MANAGER
}

enum TaskType {
  PROSPECTING
  FOLLOW_UP
  TRAINING
  OTHER
}

enum Importance {
  LOW
  MEDIUM
  HIGH
}

enum TaskCommType {
  EMAIL
  PHONE
}

model User {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String?  @unique
  title           String?
  role            String
  initials        String
  assignedClients Client[] @relation("AssignedRep")
  assignedFiles   File[]
}

model OnboardingChecklist {
  id                    String   @id @default(cuid())
  agreement_signed      Boolean  @default(false)
  property_list_created Boolean  @default(false)
  ach                   Boolean  @default(false)
  integration_setup     Boolean  @default(false)
  first_file_placed     Boolean  @default(false)
  clients               Client[]
}

model Client {
  id                          String              @id @default(cuid())
  clientId                    String?             @unique
  companyName                 String
  assignedRepId               String?
  assignedRep                 User?               @relation("AssignedRep", fields: [assignedRepId], references: [id], onDelete: SetNull)
  createdDate                 DateTime
  createdClientDate           DateTime?
  activeClientDate            DateTime?
  archiveDate                 DateTime?
  dbas                        String[]
  isCorporate                 Boolean             @default(false)
  flagged                     Boolean             @default(false)
  corporateId                 String
  firstFilePlacementDate      DateTime?
  mostRecentFilePlacementDate DateTime?
  clientStatus                ClientStatus?
  prospectStatus              ProspectStatus?
  website                     String?
  linkedIn                    String?
  address1                    String?
  address2                    String?
  city                        String?
  state                       String?
  zipCode                     String?
  contactIds                  String[]
  metadata                    Json                @default("{}")
  onboardingChecklist         OnboardingChecklist @relation(fields: [onboardingChecklistId], references: [id])
  unitCount                   Int                 @default(0)
  onboardingChecklistId       String
  auditLogs                   AuditLog[]
  files                       File[]
  tasks                       Task[]

  @@index([assignedRepId])
}

model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  title     String?
  email     String?
  phone     String?
  linkedIn  String?
  isPrimary Boolean  @default(false)
  clientIds String[]
}

model AuditLog {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  action    String
  author    String
  repId     String
  timestamp DateTime @default(now())
  type      String

  @@index([clientId, timestamp])
}

model File {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedRepId String?
  assignedRep   User?     @relation(fields: [assignedRepId], references: [id], onDelete: SetNull)
  placementDate DateTime
  collectedDate DateTime?
  fileScore     Int
  attachedFile  Bytes
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clientId, placementDate])
  @@index([assignedRepId])
  @@map("Files")
}

model Task {
  id          String        @id @default(cuid())
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  repId       String
  title       String
  description String
  taskType    TaskType
  importance  Importance
  dueDate     DateTime
  completed   Boolean       @default(false)
  automated   Boolean       @default(false)
  commType    TaskCommType?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([repId, dueDate])
  @@index([clientId])
}
